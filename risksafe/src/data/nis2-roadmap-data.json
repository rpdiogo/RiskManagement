  "complianceLevels": [
    {
      "level": "Básico",
      "description": "Medidas essenciais obrigatórias para todas as Entidades Importantes. Inclui: IAM, backup, IRP, políticas de cibersegurança, registo CNCS. Exigido desde o momento do registo."
    },
    {
      "level": "Substancial",
      "description": "Nível intermédio — encriptação, SIEM/EDR, hardening e exercícios de simulação. Exigido para sistemas e serviços de maior criticidade operacional."
    },
    {
      "level": "Elevado",
      "description": "Nível máximo — testes de penetração, análise forense avançada, monitorização contínua. Para ativos críticos com maior exposição ao risco e impacto potencial elevado."
    }
  ],
